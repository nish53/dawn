        "custom_liquid": "\n<div class=\"page-width\" style=\"display:flex;align-items:center;justify-content:space-between;padding-top:10px;padding-bottom:10px;flex-wrap:wrap;gap:8px;\">\n  <a href=\"/pages/track-order\" class=\"fv-topbar-link\" style=\"display:flex;align-items:center;gap:6px;color:#FBF9F4;text-decoration:none;font-size:13px;font-weight:600;\">\n    <svg width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\"><path d=\"M21 7.5L12 3 3 7.5m18 0L12 12m9-4.5v9L12 21m0-9L3 7.5m9 9v-9m-9 0v9l9 4.5\"/></svg>\n    Track Order\n  </a>\n  <div style=\"font-size:13px;font-weight:600;color:#E8D5B0;text-align:center;flex:1;\">\n    Free delivery across India &middot; Free installation &middot; COD available\n  </div>\n  <a href=\"tel:+918769325140\" class=\"fv-topbar-link\" style=\"display:flex;align-items:center;gap:6px;color:#FBF9F4;text-decoration:none;font-size:13px;font-weight:600;white-space:nowrap;\">\n    <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M6.6 10.8c1.4 2.8 3.7 5.1 6.5 6.5l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1.1.5 1.1 1.1V20c0 .6-.5 1.1-1.1 1.1C10.6 21.1 2.9 13.4 2.9 3.9 2.9 3.3 3.4 2.8 4 2.8h3.4c.6 0 1.1.5 1.1 1.1 0 1.2.2 2.4.6 3.6.1.4 0 .8-.2 1L6.6 10.8z\"/></svg>\n    +91 8769325140\n  </a>\n</div>\n"
