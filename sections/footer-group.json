{
  "name": "Custom Footer",
  "type": "footer",
  "sections": {
    "footer": {
      "type": "custom-liquid",
      "settings": {
        "color_scheme": "scheme-3",
        "padding_top": 0,
        "padding_bottom": 0,
        "custom_liquid": "\n<div style=\"max-width:1400px;margin:0 auto;padding:56px 24px 40px;\">\n\n  <!-- Newsletter row -->\n  <div style=\"display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:24px;\">\n    <div style=\"display:flex;align-items:center;gap:20px;\">\n      <svg width=\"48\" height=\"48\" viewBox=\"0 0 48 48\" fill=\"none\" style=\"flex-shrink:0;\">\n        <rect x=\"8\" y=\"16\" width=\"32\" height=\"24\" rx=\"2\" fill=\"#D9B98A\"/>\n        <rect x=\"8\" y=\"16\" width=\"32\" height=\"10\" fill=\"#C9A56E\"/>\n        <circle cx=\"24\" cy=\"30\" r=\"1.6\" fill=\"#5A4A2E\"/>\n        <line x1=\"4\" y1=\"40\" x2=\"4\" y2=\"46\" stroke=\"#8A6E4A\" stroke-width=\"2\"/>\n        <line x1=\"44\" y1=\"40\" x2=\"44\" y2=\"46\" stroke=\"#8A6E4A\" stroke-width=\"2\"/>\n      </svg>\n      <div>\n        <div style=\"font-family:'Poppins',sans-serif;font-weight:700;font-size:18px;color:#FBF9F4;\">Important updates waiting for you!</div>\n        <div style=\"font-size:13.5px;color:#C9BFAE;margin-top:2px;\">Subscribe and grab 20% OFF!</div>\n      </div>\n    </div>\n    <div style=\"flex:1;min-width:260px;max-width:520px;\">\n      {%- form 'customer', id: 'FurnivaFooterNewsletter', class: 'furniva-newsletter-form' -%}\n        <input type=\"hidden\" name=\"contact[tags]\" value=\"newsletter\">\n        <div style=\"display:flex;gap:0;\">\n          <input\n            type=\"email\"\n            name=\"contact[email]\"\n            required\n            placeholder=\"Email Here\"\n            style=\"flex:1;background:transparent;border:1px solid rgba(232,213,176,0.35);border-radius:6px 0 0 6px;padding:14px 18px;color:#FBF9F4;font-size:14px;outline:none;\"\n          >\n          <button\n            type=\"submit\"\n            style=\"background:#E8A33D;color:#1A1A1A;font-weight:700;font-size:14px;border:none;border-radius:0 6px 6px 0;padding:0 28px;cursor:pointer;\"\n          >Subscribe</button>\n        </div>\n        {%- if form.posted_successfully? -%}\n          <p style=\"color:#9FCB8F;font-size:12.5px;margin-top:8px;\">Thanks for subscribing!</p>\n        {%- endif -%}\n      {%- endform -%}\n    </div>\n  </div>\n\n  <hr style=\"border:none;border-top:1px solid rgba(232,213,176,0.15);margin:40px 0;\">\n\n  <!-- Logo + columns -->\n  <div style=\"display:grid;grid-template-columns:1.6fr 1fr 1fr 1fr;gap:32px;\">\n    <div>\n      <div style=\"margin-bottom:16px;\">\n        <img src=\"{{ 'furniva-logo-white.png' | asset_url }}\" alt=\"Furniva\" style=\"height:52px;width:auto;display:block;\" loading=\"lazy\">\n      </div>\n      <p style=\"font-size:13.5px;line-height:1.7;color:#C9BFAE;max-width:320px;margin:0;\">Launched in 2024, Furniva is your go-to online store for all your furniture needs. Furniva offers its consumers a world-class stage for a seamless shopping experience.</p>\n    </div>\n\n    <div>\n      <div style=\"font-family:'Poppins',sans-serif;font-weight:700;font-size:15px;color:#FBF9F4;margin-bottom:14px;\">About</div>\n      <ul style=\"list-style:none;padding:0;margin:0;\">\n        {%- assign about_links = 'About Furniva|/pages/about-us,Careers | Find Opportunities|/pages/careers,Privacy Policy|/policies/privacy-policy,News & Blogs|/blogs/news,Help Center|/pages/help-center,Terms and Conditions|/policies/terms-of-service,Warranty Policy|/pages/warranty-policy,Payment Policy|/pages/payment-policy,Best Sellers|/collections/all' | split: ',' -%}\n        {%- for item in about_links -%}\n          {%- assign parts = item | split: '|' -%}\n          <li style=\"margin-bottom:10px;\"><a href=\"{{ parts[1] }}\" style=\"color:#C9BFAE;text-decoration:none;font-size:14px;\">{{ parts[0] }}</a></li>\n        {%- endfor -%}\n      </ul>\n    </div>\n\n    <div>\n      <div style=\"font-family:'Poppins',sans-serif;font-weight:700;font-size:15px;color:#FBF9F4;margin-bottom:14px;\">Contact</div>\n      <ul style=\"list-style:none;padding:0;margin:0;\">\n        {%- assign contact_links = 'Shipping Policy|/policies/shipping-policy,Returns Policy|/policies/refund-policy,Installation Policy|/pages/installation-policy,My Account|/account,Wishlist|/pages/wishlist,Contact Us|/pages/contact,Track Order|/pages/track-order' | split: ',' -%}\n        {%- for item in contact_links -%}\n          {%- assign parts = item | split: '|' -%}\n          <li style=\"margin-bottom:10px;\"><a href=\"{{ parts[1] }}\" style=\"color:#C9BFAE;text-decoration:none;font-size:14px;\">{{ parts[0] }}</a></li>\n        {%- endfor -%}\n      </ul>\n    </div>\n\n    <div>\n      <div style=\"font-family:'Poppins',sans-serif;font-weight:700;font-size:15px;color:#FBF9F4;margin-bottom:14px;\">Support</div>\n      <p style=\"font-size:14px;color:#C9BFAE;margin:0 0 14px;\"><strong style=\"color:#FBF9F4;\">Email:</strong> info@furniva.in</p>\n      <p style=\"font-size:14px;color:#C9BFAE;margin:0 0 14px;\"><strong style=\"color:#FBF9F4;\">Phone:</strong> +91 8929722253</p>\n      <p style=\"font-size:14px;color:#C9BFAE;margin:0;\"><strong style=\"color:#FBF9F4;\">Corporate Office:</strong><br>Plot No. 33B, Manyawas, Jaipur, Rajasthan, India 302020</p>\n    </div>\n  </div>\n\n  <hr style=\"border:none;border-top:1px solid rgba(232,213,176,0.15);margin:40px 0 24px;\">\n\n  <!-- Bottom bar -->\n  <div style=\"display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;\">\n    <div style=\"font-size:13px;color:#C9BFAE;\">Furniva | Copyright &copy; {{ 'now' | date: '%Y' }} - All Rights Reserved.</div>\n    <div style=\"display:flex;gap:14px;\">\n      {%- assign socials = 'facebook,instagram,linkedin,youtube,whatsapp,pinterest,twitter' | split: ',' -%}\n      {%- assign social_urls = settings.social_facebook_link | append: '|' | append: settings.social_instagram_link | append: '|' | append: settings.social_linkedin_link | append: '|' | append: settings.social_youtube_link | append: '|' | append: settings.social_whatsapp_link | append: '|' | append: settings.social_pinterest_link | append: '|' | append: settings.social_twitter_link | split: '|' -%}\n      {%- for url in social_urls -%}\n        {%- if url != blank -%}\n          <a href=\"{{ url }}\" style=\"width:34px;height:34px;border-radius:50%;background:rgba(232,213,176,0.12);display:flex;align-items:center;justify-content:center;color:#FBF9F4;text-decoration:none;\">\n            {%- case socials[forloop.index0] -%}\n              {%- when 'facebook' -%}<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M13.5 21v-8h2.7l.4-3.2h-3.1V7.7c0-.9.3-1.6 1.7-1.6h1.6V3.2A22 22 0 0 0 14 3c-2.6 0-4.4 1.6-4.4 4.5v2.3H7v3.2h2.6V21h3.9z\"/></svg>\n              {%- when 'instagram' -%}<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M12 2.2c3.2 0 3.6 0 4.8.1 1.2 0 1.9.2 2.4.4.6.2 1 .5 1.4 1 .4.4.7.8 1 1.4.2.4.4 1.1.4 2.4.1 1.2.1 1.6.1 4.8s0 3.6-.1 4.8c0 1.2-.2 1.9-.4 2.4-.2.6-.5 1-1 1.4-.4.4-.8.7-1.4 1-.4.2-1.1.4-2.4.4-1.2.1-1.6.1-4.8.1s-3.6 0-4.8-.1c-1.2 0-1.9-.2-2.4-.4-.6-.2-1-.5-1.4-1-.4-.4-.7-.8-1-1.4-.2-.4-.4-1.1-.4-2.4C2.2 15.6 2.2 15.2 2.2 12s0-3.6.1-4.8c0-1.2.2-1.9.4-2.4.2-.6.5-1 1-1.4.4-.4.8-.7 1.4-1 .4-.2 1.1-.4 2.4-.4C8.4 2.2 8.8 2.2 12 2.2zm0 1.8c-3.1 0-3.5 0-4.7.1-1 0-1.5.2-1.9.3-.5.2-.8.4-1.1.7-.3.3-.5.6-.7 1.1-.1.4-.3.9-.3 1.9-.1 1.2-.1 1.6-.1 4.7s0 3.5.1 4.7c0 1 .2 1.5.3 1.9.2.5.4.8.7 1.1.3.3.6.5 1.1.7.4.1.9.3 1.9.3 1.2.1 1.6.1 4.7.1s3.5 0 4.7-.1c1 0 1.5-.2 1.9-.3.5-.2.8-.4 1.1-.7.3-.3.5-.6.7-1.1.1-.4.3-.9.3-1.9.1-1.2.1-1.6.1-4.7s0-3.5-.1-4.7c0-1-.2-1.5-.3-1.9-.2-.5-.4-.8-.7-1.1-.3-.3-.6-.5-1.1-.7-.4-.1-.9-.3-1.9-.3-1.2-.1-1.6-.1-4.7-.1zm0 4.3a5.7 5.7 0 1 1 0 11.4 5.7 5.7 0 0 1 0-11.4zm0 1.8a3.9 3.9 0 1 0 0 7.8 3.9 3.9 0 0 0 0-7.8zm5.9-2a1.3 1.3 0 1 1 0 2.7 1.3 1.3 0 0 1 0-2.7z\"/></svg>\n              {%- when 'linkedin' -%}<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.38-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.13 2.07 2.07 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45z\"/></svg>\n              {%- when 'youtube' -%}<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M22 12a29 29 0 0 0-.4-5.3 3 3 0 0 0-2.1-2C17.7 4.2 12 4.2 12 4.2s-5.7 0-7.5.5a3 3 0 0 0-2.1 2A29 29 0 0 0 2 12a29 29 0 0 0 .4 5.3 3 3 0 0 0 2.1 2c1.8.5 7.5.5 7.5.5s5.7 0 7.5-.5a3 3 0 0 0 2.1-2A29 29 0 0 0 22 12zM9.9 15.5v-7l6 3.5z\"/></svg>\n              {%- when 'whatsapp' -%}<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.87 9.87 0 0 0 4.74 1.21h.01c5.46 0 9.91-4.45 9.91-9.91C21.96 6.45 17.5 2 12.04 2z\"/></svg>\n              {%- when 'pinterest' -%}<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M12 2a10 10 0 0 0-3.6 19.3c0-.8-.02-2 .2-2.9l1.3-5.6s-.3-.7-.3-1.6c0-1.5.9-2.6 2-2.6.9 0 1.4.7 1.4 1.6 0 .9-.6 2.3-.9 3.6-.3 1.1.5 2 1.6 2 1.9 0 3.2-2.4 3.2-5.3 0-2.2-1.5-3.9-4.2-3.9-3 0-4.9 2.3-4.9 4.8 0 .9.3 1.5.7 2 .2.2.2.3.1.5l-.2.9c-.1.3-.3.4-.5.2-1.4-.6-2.1-2.2-2.1-4 0-3 2.5-6.5 7.5-6.5 4 0 6.6 2.9 6.6 6 0 4.1-2.3 7.2-5.6 7.2-1.1 0-2.2-.6-2.5-1.3l-.7 2.7c-.2.9-.7 2-1.1 2.7A10 10 0 1 0 12 2z\"/></svg>\n              {%- when 'twitter' -%}<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M18.9 3H22l-7.2 8.3L23 21h-6.6l-5.2-6.8L5.2 21H2l7.7-8.8L2 3h6.7l4.7 6.2L18.9 3z\"/></svg>\n            {%- endcase -%}\n          </a>\n        {%- endif -%}\n      {%- endfor -%}\n    </div>\n  </div>\n</div>\n\n<a href=\"#top\" id=\"fv-back-to-top\" style=\"position:fixed;bottom:24px;right:24px;width:44px;height:44px;background:#E8A33D;border-radius:8px;display:flex;align-items:center;justify-content:center;color:#1A1A1A;text-decoration:none;box-shadow:0 2px 8px rgba(0,0,0,0.25);z-index:99;\">\n  <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\"><path d=\"M12 19V5M5 12l7-7 7 7\"/></svg>\n</a>\n"
      }
    }
  },
  "order": [
    "footer"
  ]
}