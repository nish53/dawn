{{ 'component-card.css' | asset_url | stylesheet_tag }}

<div class="page-width" style="text-align:center;padding:{{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  {%- if section.settings.eyebrow != blank -%}
    <p style="font-size:11px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:#f4a51c;margin-bottom:4px;">{{ section.settings.eyebrow }}</p>
  {%- endif -%}
  {%- if section.settings.heading != blank -%}
    <h2 style="font-family:'Poppins',sans-serif;font-size:18px;font-weight:600;margin:0 0 8px;">{{ section.settings.heading }}</h2>
  {%- endif -%}
  {%- if section.settings.subheading != blank -%}
    <p style="font-size:13px;color:#666;margin-bottom:24px;">{{ section.settings.subheading }}</p>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div style="display:flex;gap:16px;overflow-x:auto;justify-content:center;">
      {%- for block in section.blocks -%}
        {%- assign product = block.settings.product -%}
        <div
          class="fv-video-card"
          data-video-modal="fv-video-{{ block.id }}"
          style="cursor:pointer;width:200px;flex-shrink:0;text-align:left;"
          {{ block.shopify_attributes }}
        >
          <div style="position:relative;border-radius:10px;overflow:hidden;aspect-ratio:9/16;background:#152420;">
            {%- if block.settings.thumbnail -%}
              <img src="{{ block.settings.thumbnail | image_url: width: 400 }}" alt="{{ block.settings.thumbnail.alt | default: 'Video thumbnail' }}" style="width:100%;height:100%;object-fit:cover;opacity:0.85;">
            {%- else -%}
              <div style="width:100%;height:100%;background:#2A3F3A;"></div>
            {%- endif -%}
            {%- if block.settings.view_count != blank -%}
              <div style="position:absolute;top:8px;left:8px;background:rgba(0,0,0,0.55);color:#fff;font-size:11px;font-weight:600;padding:3px 8px;border-radius:20px;display:flex;align-items:center;gap:4px;">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                {{ block.settings.view_count }}
              </div>
            {%- endif -%}
            <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;">
              <div style="width:44px;height:44px;border-radius:50%;background:rgba(255,255,255,0.9);display:flex;align-items:center;justify-content:center;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#152420"><path d="M8 5v14l11-7z"/></svg>
              </div>
            </div>
          </div>
          {%- if product != blank -%}
            <div style="margin-top:8px;font-size:12.5px;font-weight:600;color:#152420;">{{ product.title }}</div>
            <div style="font-size:12px;color:#3a3a3a;">
              {{ product.price | money }}
              {%- if product.compare_at_price > product.price -%}
                <s style="color:#999;">{{ product.compare_at_price | money }}</s>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    {%- for block in section.blocks -%}
      {%- assign product = block.settings.product -%}
      <div
        id="fv-video-{{ block.id }}"
        class="fv-video-modal-overlay"
        data-video-type="{{ block.settings.video_type }}"
        style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:300;align-items:center;justify-content:center;padding:20px;"
      >
        <div style="background:#fff;border-radius:14px;max-width:360px;width:100%;overflow:hidden;position:relative;">
          <button type="button" class="fv-video-close" style="position:absolute;top:10px;right:10px;background:rgba(0,0,0,0.6);color:#fff;border:none;border-radius:50%;width:30px;height:30px;font-size:16px;cursor:pointer;z-index:2;">&times;</button>
          {%- if block.settings.video_type == 'iframe' -%}
            <div class="fv-video-slot" data-iframe-src="{{ block.settings.video_url }}" style="width:100%;height:480px;background:#000;"></div>
          {%- else -%}
            <div class="fv-video-slot" data-video-src="{{ block.settings.video_url }}" style="width:100%;height:480px;background:#000;"></div>
          {%- endif -%}
          {%- if product != blank -%}
            <div style="padding:14px 16px;display:flex;align-items:center;gap:12px;border-top:1px solid #EDEBE5;">
              {%- if product.featured_image -%}
                <img src="{{ product.featured_image | image_url: width: 100 }}" alt="{{ product.title }}" style="width:48px;height:48px;object-fit:cover;border-radius:6px;">
              {%- endif -%}
              <div style="flex:1;text-align:left;">
                <div style="font-size:13px;font-weight:600;color:#152420;">{{ product.title }}</div>
                <div style="font-size:12.5px;color:#3a3a3a;">
                  {{ product.price | money }}
                  {%- if product.compare_at_price > product.price -%}
                    <s style="color:#999;">{{ product.compare_at_price | money }}</s>
                  {%- endif -%}
                </div>
              </div>
              <a href="{{ product.url }}" style="background:#152420;color:#fff;text-decoration:none;font-size:12px;font-weight:600;padding:9px 14px;border-radius:8px;white-space:nowrap;">View Product</a>
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  {%- else -%}
    <p style="font-size:13px;color:#999;">No videos added yet - add a "Video" block in the theme editor to get started.</p>
  {%- endif -%}
</div>

<script>
  (function () {
    document.querySelectorAll('[data-video-modal]').forEach(function (card) {
      card.addEventListener('click', function () {
        var modal = document.getElementById(card.getAttribute('data-video-modal'));
        if (!modal) return;
        var slot = modal.querySelector('.fv-video-slot');
        var type = modal.getAttribute('data-video-type');

        if (type === 'iframe') {
          var src = slot.getAttribute('data-iframe-src');
          slot.innerHTML = '<iframe src="' + src + '" width="100%" height="100%" frameborder="0" scrolling="no" allowtransparency="true" allow="autoplay"></iframe>';
        } else {
          var vsrc = slot.getAttribute('data-video-src');
          slot.innerHTML = '<video src="' + vsrc + '" width="100%" height="100%" style="object-fit:cover;" controls autoplay playsinline></video>';
        }

        modal.style.display = 'flex';
      });
    });

    function closeModal(overlay) {
      var slot = overlay.querySelector('.fv-video-slot');
      slot.innerHTML = '';
      overlay.style.display = 'none';
    }

    document.querySelectorAll('.fv-video-modal-overlay').forEach(function (overlay) {
      overlay.querySelector('.fv-video-close').addEventListener('click', function () {
        closeModal(overlay);
      });
      overlay.addEventListener('click', function (e) {
        if (e.target === overlay) closeModal(overlay);
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Shoppable Videos",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "As seen on"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real unboxings. Real homes."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "image_picker",
          "id": "thumbnail",
          "label": "Thumbnail image"
        },
        {
          "type": "text",
          "id": "view_count",
          "label": "View count label",
          "info": "e.g. 2K, 8K - leave blank to hide",
          "default": "1K"
        },
        {
          "type": "select",
          "id": "video_type",
          "label": "Video type",
          "options": [
            { "value": "iframe", "label": "Embedded (Instagram/TikTok/YouTube)" },
            { "value": "native", "label": "Self-hosted video file" }
          ],
          "default": "iframe"
        },
        {
          "type": "text",
          "id": "video_url",
          "label": "Video URL",
          "info": "For embeds: paste the embed URL (e.g. instagram.com/p/XXX/embed). For self-hosted: paste the file URL from Shopify Admin > Content > Files."
        },
        {
          "type": "product",
          "id": "product",
          "label": "Linked product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shoppable Videos",
      "blocks": [
        { "type": "video" }
      ]
    }
  ]
}
{% endschema %}
