{%- liquid
  assign bg_colors = '#EAEAEA,#B9CFCB,#B7BDD1' | split: ','
-%}

<div class="page-width">
  {%- if section.blocks.size > 0 -%}
    <div style="display:grid;grid-template-columns:repeat({{ section.blocks.size }}, 1fr);gap:16px;">
      {%- for block in section.blocks -%}
        {%- assign bg = block.settings.background_color | default: bg_colors[forloop.index0] -%}
        {%- assign text_right = false -%}
        {%- if block.settings.text_position == 'right' -%}
          {%- assign text_right = true -%}
        {%- endif -%}
        {%- assign box_ratio = 75 -%}
        {%- if block.settings.image.aspect_ratio -%}
          {%- assign box_ratio = 100.0 | divided_by: block.settings.image.aspect_ratio -%}
        {%- endif -%}
        <div
          style="background:{{ bg }};border-radius:10px;overflow:hidden;position:relative;height:0;padding-bottom:{{ box_ratio }}%;"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.image -%}
            <img
              src="{{ block.settings.image | image_url: width: 600 }}"
              alt="{{ block.settings.image.alt | default: block.settings.heading }}"
              style="position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;"
            >
          {%- endif -%}
          <div style="position:absolute;top:0;left:0;width:100%;height:100%;{% if text_right %}text-align:right;{% endif %}">
            {%- if block.settings.heading != blank -%}
              <h3 style="font-family:'Poppins',sans-serif;font-weight:800;font-size:17.25px;line-height:1.2;color:#152420;margin:20% {% if text_right %}6%{% else %}55%{% endif %} 0 {% if text_right %}55%{% else %}6%{% endif %};">{{ block.settings.heading }}</h3>
            {%- endif -%}
            {%- if block.settings.link_text != blank -%}
              <a href="{{ block.settings.link | default: '#' }}" style="font-family:'Poppins',sans-serif;font-size:12.65px;font-weight:600;line-height:1.2em;color:#044594;text-decoration:none;display:block;margin:1% {% if text_right %}6%{% else %}50%{% endif %} 0 {% if text_right %}50%{% else %}6%{% endif %};">{{ block.settings.link_text }}</a>
            {%- endif -%}
            {%- if block.settings.subtext != blank -%}
              <div style="font-size:10.5px;line-height:1.2em;margin:1% {% if text_right %}6%{% else %}50%{% endif %} 0 {% if text_right %}50%{% else %}6%{% endif %};">{{ block.settings.subtext }}</div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  {%- else -%}
    <p style="font-size:13px;color:#999;text-align:center;">No columns added yet - add a "Column" block in the theme editor to get started.</p>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Category Banner (Overlay)",
  "settings": [],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "color",
          "id": "background_color",
          "label": "Background color",
          "info": "Leave unset to use the default rotating color"
        },
        {
          "type": "select",
          "id": "text_position",
          "label": "Text position",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Column heading"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link text",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtext",
          "info": "e.g. pricing or a short offer line"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Banner (Overlay)",
      "blocks": [
        { "type": "column" },
        { "type": "column" },
        { "type": "column" }
      ]
    }
  ]
}
{% endschema %}
