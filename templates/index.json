    "category_grid": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<div style=\"max-width:1200px;margin:0 auto;padding:0 1.5rem;\">\n  <p style=\"font-size:11px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:#8A6E4A;margin-bottom:4px;\">Browse by category</p>\n  <h2 style=\"font-family:'Poppins',sans-serif;font-size:24px;font-weight:600;margin:0 0 4px;\">Shop every room</h2>\n  <p style=\"font-size:13px;color:#666;margin-bottom:20px;\">Curated furniture for every corner of your home</p>\n  <div style=\"display:grid;grid-template-columns:repeat(5,1fr);gap:10px;\">\n    {% assign cats = 'beds,storage-units,dining-kitchen,work-study,tv-entertainment-units' | split: ',' %}\n    {% assign cat_labels = 'Beds,Storage,Dining,Study,TV Units' | split: ',' %}\n    {% for handle in cats %}\n      {% assign collection = collections[handle] %}\n      {% if collection %}\n      <a href=\"{{ collection.url }}\" style=\"text-decoration:none;color:inherit;border:1px solid #EAEAEA;border-radius:8px;overflow:hidden;display:block;\">\n        {% if collection.image %}\n          <img src=\"{{ collection.image | image_url: width: 300 }}\" alt=\"{{ collection.title }}\" style=\"width:100%;height:110px;object-fit:cover;display:block;\">\n        {% else %}\n          <div style=\"width:100%;height:110px;background:#F7F5F1;\"></div>\n        {% endif %}\n        <div style=\"padding:10px;\">\n          <div style=\"font-size:13px;font-weight:600;\">{{ cat_labels[forloop.index0] }}</div>\n          <div style=\"font-size:11px;color:#888;\">{{ collection.products_count }} products</div>\n        </div>\n      </a>\n      {% endif %}\n    {% endfor %}\n  </div>\n</div>",
        "color_scheme": "scheme-1"
      }
    },
