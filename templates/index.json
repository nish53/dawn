      "settings": {
        "custom_liquid": "<div class=\"page-width\">\n  <div style=\"display:grid;grid-template-columns:repeat(3,1fr);gap:12px;\">\n    <div style=\"background:#F7F5F1;border-radius:8px;padding:20px;text-align:center;\">\n      <div style=\"font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#f4a51c;margin-bottom:4px;\">Amazon</div>\n      <div style=\"font-family:'Poppins',sans-serif;font-size:18px;font-weight:600;\">Coming soon</div>\n      <div style=\"font-size:11px;color:#666;margin-top:2px;\">Rating sync in progress</div>\n    </div>\n    <div style=\"background:#152420;border-radius:8px;padding:20px;text-align:center;\">\n      <div style=\"font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#f4a51c;margin-bottom:4px;\">Flipkart</div>\n      <div style=\"font-family:'Poppins',sans-serif;font-size:18px;font-weight:600;color:#FFFFFF;\">Coming soon</div>\n      <div style=\"font-size:11px;color:#D8D3C8;margin-top:2px;\">Rating sync in progress</div>\n    </div>\n    <div style=\"background:#F7F5F1;border-radius:8px;padding:20px;text-align:center;\">\n      <div style=\"font-family:'Poppins',sans-serif;font-size:20px;font-weight:600;color:#152420;\">0</div>\n      <div style=\"font-size:11px;color:#666;margin-top:2px;\">Reviews collected so far &middot; Since 2024</div>\n    </div>\n  </div>\n</div>",
