    "seo_text": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<div style=\"max-width:900px;margin:0 auto;padding:0 1.5rem;\">\n  <h2 style=\"font-family:'Poppins',sans-serif;font-size:17px;font-weight:600;margin:0 0 10px;\">Buy Wooden Furniture Online for Modern and Stylish Homes</h2>\n  <div style=\"font-size:12.5px;line-height:1.7;color:#555;\">\n    <p style=\"margin:0 0 10px;\">Looking to upgrade your space with beautiful and bold furniture? Explore our handpicked collection of wooden and engineered wood furniture made for modern homes and busy offices. From wooden shoe racks to compact cabinets and spacious wardrobes, we have everything you need to stay organized in style.</p>\n    <p style=\"margin:0 0 10px;\">Are you a new Furniva customer in need of a stylish shoe organizer? Look no more &mdash; our wooden shoe racks offer sleek solutions to keep your footwear in place while adding charm to your hallway or even bedroom.</p>\n    <p style=\"margin:0;\">Our furniture is crafted from premium engineered wood, ensuring quality as well as durability without compromising on style, with multiple finishes and sizes to suit any home.</p>\n  </div>\n</div>",
        "color_scheme": "scheme-4",
        "padding_top": 32,
        "padding_bottom": 32
      }
    },
