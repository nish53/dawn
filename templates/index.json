        "custom_liquid": "<div style=\"max-width:1200px;margin:0 auto;padding:0 1.5rem;\">\n  <div style=\"display:grid;grid-template-columns:repeat(3,1fr);gap:12px;\">\n    <div style=\"background:#F7F5F1;border-radius:8px;padding:20px;text-align:center;\">\n      <div style=\"font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#8A6E4A;margin-bottom:4px;\">Amazon</div>\n      <div style=\"font-family:'Poppins',sans-serif;font-size:22px;font-weight:600;\">Coming soon</div>\n      <div style=\"font-size:11px;color:#666;margin-top:2px;\">Rating sync in progress</div>\n    </div>\n    <div style=\"background:#F7F5F1;border-radius:8px;padding:20px;text-align:center;\">\n      <div style=\"font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#8A6E4A;margin-bottom:4px;\">Flipkart</div>\n      <div style=\"font-family:'Poppins',sans-serif;font-size:22px;font-weight:600;\">Coming soon</div>\n      <div style=\"font-size:11px;color:#666;margin-top:2px;\">Rating sync in progress</div>\n    </div>\n    <div style=\"background:#1A1A1A;border-radius:8px;padding:20px;text-align:center;\">\n      <div style=\"font-family:'Poppins',sans-serif;font-size:26px;font-weight:600;color:#E8D5B0;\">0</div>\n      <div style=\"font-size:11px;color:#A89070;margin-top:2px;\">Reviews collected so far &middot; Since 2024</div>\n    </div>\n  </div>\n</div>",
