{
  "sections": {
    "main": {
      "type": "custom-liquid",
      "settings": {
        "color_scheme": "scheme-1",
        "padding_top": 0,
        "padding_bottom": 0,
        "custom_liquid": "<div class=\"page-width\" style=\"padding:30px 0 50px;\">\n\n  <div style=\"text-align:center;margin-bottom:36px;\">\n    <h1 style=\"font-family:'Poppins',sans-serif;font-size:30px;font-weight:700;color:#152420;margin-bottom:10px;\">Hi, how can we help you?</h1>\n    <p style=\"font-size:14px;color:#666;\">Can't find the answer you're looking for?</p>\n  </div>\n\n  <!-- QUICK HELP CARDS - dark green, icon + white uppercase text - open real popups, matching the old site -->\n  <div style=\"display:grid;grid-template-columns:repeat(auto-fit, minmax(220px, 1fr));gap:16px;margin-bottom:14px;\">\n    <button type=\"button\" data-fv-popup=\"fv-popup-order\" style=\"cursor:pointer;font-family:inherit;text-decoration:none;background:#152420;border:none;border-radius:10px;padding:26px 20px;text-align:center;display:flex;flex-direction:column;align-items:center;gap:12px;\">\n      <svg width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#f4a51c\" stroke-width=\"1.6\"><path d=\"M1 3h13v13H1z\"/><path d=\"M14 8h4l3 3v5h-7z\"/><circle cx=\"6\" cy=\"18\" r=\"2\"/><circle cx=\"17\" cy=\"18\" r=\"2\"/></svg>\n      <div style=\"font-size:13px;font-weight:700;text-transform:uppercase;color:#fff;letter-spacing:0.02em;\">Where is my order?</div>\n    </button>\n    <button type=\"button\" data-fv-popup=\"fv-popup-returns\" style=\"cursor:pointer;font-family:inherit;text-decoration:none;background:#152420;border:none;border-radius:10px;padding:26px 20px;text-align:center;display:flex;flex-direction:column;align-items:center;gap:12px;\">\n      <svg width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#f4a51c\" stroke-width=\"1.6\"><path d=\"M21 12a9 9 0 1 1-3-6.7\"/><path d=\"M21 3v6h-6\"/></svg>\n      <div style=\"font-size:13px;font-weight:700;text-transform:uppercase;color:#fff;letter-spacing:0.02em;\">I want to return an item</div>\n    </button>\n    <button type=\"button\" data-fv-popup=\"fv-popup-cancel\" style=\"cursor:pointer;font-family:inherit;text-decoration:none;background:#152420;border:none;border-radius:10px;padding:26px 20px;text-align:center;display:flex;flex-direction:column;align-items:center;gap:12px;\">\n      <svg width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#f4a51c\" stroke-width=\"1.6\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><path d=\"M15 9l-6 6M9 9l6 6\"/></svg>\n      <div style=\"font-size:13px;font-weight:700;text-transform:uppercase;color:#fff;letter-spacing:0.02em;\">I want to cancel an order</div>\n    </button>\n  </div>\n\n  <!-- POPUP MODALS -->\n  <div id=\"fv-popup-order\" class=\"fv-popup-overlay\" style=\"display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:200;align-items:center;justify-content:center;padding:20px;\">\n    <div style=\"background:#fff;border-radius:12px;max-width:600px;width:100%;max-height:85vh;overflow-y:auto;padding:36px;position:relative;\">\n      <button type=\"button\" class=\"fv-popup-close\" style=\"position:absolute;top:16px;right:16px;background:#1A1A1A;color:#fff;border:none;border-radius:50%;width:32px;height:32px;font-size:16px;cursor:pointer;\">&times;</button>\n      <h2 style=\"font-family:'Poppins',sans-serif;font-size:24px;font-weight:700;color:#152420;margin-bottom:12px;\">Where is my order?</h2>\n      <hr style=\"border:none;border-top:1px solid #EDEBE5;margin-bottom:20px;\">\n      <div style=\"font-size:14px;color:#3a3a3a;line-height:1.8;\">\n        <p style=\"margin-bottom:10px;\"><strong>Tracking Your Order</strong><br>To track your order, please visit our <a href=\"/pages/tracking\" style=\"color:#2C5F8A;font-weight:600;\">Tracking Page</a>.</p>\n        <p style=\"margin-bottom:8px;\">You may track your order using one of the following methods:</p>\n        <p style=\"margin-bottom:6px;\"><strong>1. Email/Phone Number and Order Number:</strong><br>Enter your registered email address or phone number, and your specific order number.</p>\n        <p style=\"margin-bottom:10px;\"><strong>2. Tracking ID:</strong><br>Locate your unique tracking ID on the \"My Orders\" page under your \"My Account\" section, then enter it directly into the tracking page.</p>\n        <p style=\"margin-bottom:10px;\">Once you've entered the correct information, you'll be able to view the real-time status of your order.</p>\n        <p><strong>If you encounter any difficulties or have further questions, please don't hesitate to contact our customer support team.</strong></p>\n      </div>\n    </div>\n  </div>\n\n  <div id=\"fv-popup-returns\" class=\"fv-popup-overlay\" style=\"display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:200;align-items:center;justify-content:center;padding:20px;\">\n    <div style=\"background:#fff;border-radius:12px;max-width:600px;width:100%;max-height:85vh;overflow-y:auto;padding:36px;position:relative;\">\n      <button type=\"button\" class=\"fv-popup-close\" style=\"position:absolute;top:16px;right:16px;background:#1A1A1A;color:#fff;border:none;border-radius:50%;width:32px;height:32px;font-size:16px;cursor:pointer;\">&times;</button>\n      <h2 style=\"font-family:'Poppins',sans-serif;font-size:24px;font-weight:700;color:#152420;margin-bottom:12px;\">Returns</h2>\n      <hr style=\"border:none;border-top:1px solid #EDEBE5;margin-bottom:20px;\">\n      <div style=\"font-size:14px;color:#3a3a3a;line-height:1.8;\">\n        <p style=\"margin-bottom:10px;\"><strong>At Furniva, customer satisfaction is our top priority.</strong><br>In case you receive a damaged, defective, or incorrect item, you're eligible for a free replacement within 3 days of delivery. For returns, please ensure the product is in its original condition with all packaging and accessories intact.</p>\n        <p style=\"margin-bottom:10px;\"><strong>Change of mind is not applicable</strong> as a Return Reason for this product.</p>\n        <p style=\"margin-bottom:10px;\">Refunds are processed promptly once the item is returned to us. For full details, please refer to our complete <a href=\"/policies/refund-policy\" style=\"color:#2C5F8A;font-weight:600;text-decoration:underline;\">Return and Refund Policy</a>.</p>\n        <p>If so, please <a href=\"mailto:support@furniva.in\" style=\"color:#2C5F8A;font-weight:600;text-decoration:underline;\">email us</a> within 3 days of the delivery date.</p>\n      </div>\n    </div>\n  </div>\n\n  <div id=\"fv-popup-cancel\" class=\"fv-popup-overlay\" style=\"display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:200;align-items:center;justify-content:center;padding:20px;\">\n    <div style=\"background:#fff;border-radius:12px;max-width:600px;width:100%;max-height:85vh;overflow-y:auto;padding:36px;position:relative;\">\n      <button type=\"button\" class=\"fv-popup-close\" style=\"position:absolute;top:16px;right:16px;background:#1A1A1A;color:#fff;border:none;border-radius:50%;width:32px;height:32px;font-size:16px;cursor:pointer;\">&times;</button>\n      <h2 style=\"font-family:'Poppins',sans-serif;font-size:24px;font-weight:700;color:#152420;margin-bottom:12px;\">Canceling an Order at Furniva</h2>\n      <hr style=\"border:none;border-top:1px solid #EDEBE5;margin-bottom:20px;\">\n      <div style=\"font-size:14px;color:#3a3a3a;line-height:1.8;\">\n        <p style=\"margin-bottom:14px;\"><strong>1. Order Confirmation:</strong><br>We confirm all orders via a phone call to ensure 100% clarity and satisfaction. If you haven't received a confirmation call yet, please wait for our team to contact you.</p>\n        <p style=\"margin-bottom:14px;\"><strong>2. Eligible Order Statuses for Cancellation:</strong><br>You can cancel your order if its status is one of the following: <strong>On Hold, Processing, or Pending Payment</strong>.</p>\n        <p style=\"margin-bottom:14px;\"><strong>3. Orders in Transit:</strong><br>If your order has already been shipped, direct cancellation is not available. For assistance, please reach out to our support team.</p>\n        <p style=\"margin-bottom:14px;\"><strong>4. Cancellation Charges:</strong><br>In cases where an order is already in transit, a cancellation fee may apply, depending on the shipment status.</p>\n        <p><strong>If you have further questions, our support team is here to help!</strong></p>\n      </div>\n    </div>\n  </div>\n\n  <script>\n    (function () {\n      document.querySelectorAll('[data-fv-popup]').forEach(function (btn) {\n        btn.addEventListener('click', function () {\n          var popup = document.getElementById(btn.getAttribute('data-fv-popup'));\n          if (popup) popup.style.display = 'flex';\n        });\n      });\n      document.querySelectorAll('.fv-popup-overlay').forEach(function (overlay) {\n        overlay.querySelector('.fv-popup-close').addEventListener('click', function () {\n          overlay.style.display = 'none';\n        });\n        overlay.addEventListener('click', function (e) {\n          if (e.target === overlay) overlay.style.display = 'none';\n        });\n      });\n    })();\n  </script>\n\n  <div style=\"margin-bottom:44px;font-size:13.5px;color:#444;\">\n    Have another question? <a href=\"/pages/help-center\" style=\"color:#152420;font-weight:700;text-decoration:underline;\">BROWSE HELP CENTER &rsaquo;</a>\n  </div>\n\n  <hr style=\"border:none;border-top:1px solid #EDEBE5;margin-bottom:36px;\">\n\n  <div style=\"text-align:center;margin-bottom:8px;\">\n    <h2 style=\"font-family:'Poppins',sans-serif;font-size:24px;font-weight:700;color:#152420;display:inline-block;position:relative;\">Contact Us!\n      <div style=\"border-bottom:3px dotted #152420;width:60%;margin:6px auto 0;\"></div>\n    </h2>\n  </div>\n\n  <div style=\"display:grid;grid-template-columns:1fr 1.3fr;gap:40px;margin:32px 0 40px;align-items:center;\">\n    <div style=\"text-align:center;\">\n      <svg width=\"220\" height=\"180\" viewBox=\"0 0 220 180\" fill=\"none\">\n        <ellipse cx=\"110\" cy=\"165\" rx=\"90\" ry=\"10\" fill=\"#F5F0E8\"/>\n        <rect x=\"120\" y=\"70\" width=\"16\" height=\"90\" rx=\"2\" fill=\"#8A6E4A\"/>\n        <rect x=\"95\" y=\"55\" width=\"70\" height=\"55\" rx=\"8\" fill=\"#2C5F8A\"/>\n        <rect x=\"95\" y=\"55\" width=\"70\" height=\"14\" rx=\"6\" fill=\"#3D72A4\"/>\n        <path d=\"M105 100 L130 78 L155 100 Z\" fill=\"#f4a51c\" stroke=\"#152420\" stroke-width=\"2\"/>\n        <rect x=\"118\" y=\"85\" width=\"24\" height=\"20\" fill=\"#fff\"/>\n        <circle cx=\"60\" cy=\"120\" r=\"22\" fill=\"#152420\"/>\n        <rect x=\"48\" y=\"100\" width=\"24\" height=\"30\" rx=\"4\" fill=\"#f4a51c\"/>\n        <circle cx=\"80\" cy=\"70\" r=\"5\" fill=\"#EDEBE5\"/>\n        <circle cx=\"170\" cy=\"90\" r=\"4\" fill=\"#EDEBE5\"/>\n        <circle cx=\"40\" cy=\"60\" r=\"3\" fill=\"#EDEBE5\"/>\n      </svg>\n    </div>\n    <div>\n      <div style=\"font-size:14px;color:#444;line-height:1.9;margin-bottom:16px;\">\n        <p><strong>For order status inquiry</strong>, please visit your order page <a href=\"/account\" style=\"color:#2C5F8A;font-weight:600;\">here</a>.</p>\n        <p>For tracking updates, please visit <a href=\"/pages/tracking\" style=\"color:#2C5F8A;font-weight:600;text-decoration:underline;\">this page</a>.</p>\n        <p><strong>For other concerns</strong>, feel free to visit our Help Center Page <a href=\"/pages/help-center\" style=\"color:#2C5F8A;font-weight:600;\">here</a>.</p>\n      </div>\n      <p style=\"font-size:13.5px;color:#444;margin-bottom:12px;\">Can't find the answer you are looking for?</p>\n      <a href=\"mailto:support@furniva.in\" style=\"display:inline-flex;align-items:center;gap:8px;background:#152420;color:#fff;text-decoration:none;padding:11px 20px;border-radius:8px;font-size:13.5px;font-weight:700;margin-bottom:14px;\">\n        <svg width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M22 2 11 13\"/><path d=\"M22 2 15 22l-4-9-9-4Z\"/></svg>\n        Email Us Now!\n      </a>\n      <p style=\"font-size:13.5px;color:#444;\">Still having trouble? <a href=\"tel:+918769325140\" style=\"color:#2C5F8A;font-weight:600;text-decoration:underline;\">Call Us!</a></p>\n    </div>\n  </div>\n\n  <div style=\"display:grid;grid-template-columns:1.2fr 1fr;gap:40px;margin-bottom:40px;\">\n    <div>\n      <h2 style=\"font-family:'Poppins',sans-serif;font-size:20px;font-weight:700;color:#152420;margin-bottom:16px;\">Get in touch</h2>\n      {% form 'contact' %}\n        {%- if form.posted_successfully? -%}\n          <p style=\"color:#2f6b1f;font-size:13px;margin-bottom:12px;\">Thanks - we've received your message and will get back to you shortly.</p>\n        {%- endif -%}\n        <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;\">\n          <input type=\"text\" name=\"contact[name]\" placeholder=\"Your Name\" style=\"padding:11px 14px;border:1px solid #EDEBE5;border-radius:8px;font-size:13px;\">\n          <input type=\"email\" name=\"contact[email]\" placeholder=\"Your Email\" required style=\"padding:11px 14px;border:1px solid #EDEBE5;border-radius:8px;font-size:13px;\">\n        </div>\n        <div style=\"display:flex;flex-direction:column;gap:12px;\">\n          <input type=\"text\" name=\"contact[subject]\" placeholder=\"Subject\" style=\"padding:11px 14px;border:1px solid #EDEBE5;border-radius:8px;font-size:13px;\">\n          <textarea name=\"contact[body]\" rows=\"5\" placeholder=\"Your Message\" required style=\"padding:11px 14px;border:1px solid #EDEBE5;border-radius:8px;font-size:13px;font-family:inherit;\"></textarea>\n          <button type=\"submit\" style=\"background:#152420;color:#fff;border:none;padding:12px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;\">Send Message</button>\n        </div>\n      {% endform %}\n    </div>\n    <div>\n      <h2 style=\"font-family:'Poppins',sans-serif;font-size:20px;font-weight:700;color:#152420;margin-bottom:16px;\">Our Corporate Office</h2>\n      <div style=\"border-radius:10px;overflow:hidden;margin-bottom:16px;border:1px solid #EDEBE5;\">\n        <iframe\n          src=\"https://www.openstreetmap.org/export/embed.html?bbox=75.70%2C26.79%2C75.80%2C26.86&layer=mapnik&marker=26.822%2C75.752\"\n          style=\"width:100%;height:220px;border:none;display:block;\"\n          loading=\"lazy\">\n        </iframe>\n      </div>\n      <div style=\"display:grid;grid-template-columns:1fr;gap:16px;\">\n        <div>\n          <div style=\"font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:#8A6E4A;font-weight:600;margin-bottom:4px;\">Address</div>\n          <div style=\"font-size:13.5px;color:#333;\">Himank Path, Ganpati Nagar, Manyawas, Jaipur, Rajasthan, India &ndash; 302020</div>\n        </div>\n        <div>\n          <div style=\"font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:#8A6E4A;font-weight:600;margin-bottom:4px;\">Phone</div>\n          <div style=\"font-size:13.5px;color:#333;\">+91 8769325140 &mdash; Everyday 9am to 6pm</div>\n        </div>\n        <div>\n          <div style=\"font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:#8A6E4A;font-weight:600;margin-bottom:4px;\">Email</div>\n          <div style=\"font-size:13.5px;color:#333;\">support@furniva.in</div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n</div>"
      }
    }
  },
  "order": [
    "main"
  ]
}