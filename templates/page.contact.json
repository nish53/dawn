{
  "sections": {
    "main": {
      "type": "custom-liquid",
      "settings": {
        "color_scheme": "scheme-1",
        "padding_top": 0,
        "padding_bottom": 0,
        "custom_liquid": "<div class=\"page-width\" style=\"padding:30px 0 50px;\">\n\n  <div style=\"text-align:center;margin-bottom:36px;\">\n    <h1 style=\"font-family:'Poppins',sans-serif;font-size:30px;font-weight:700;color:#152420;margin-bottom:10px;\">Hi, how can we help you?</h1>\n    <p style=\"font-size:14px;color:#666;\">Can't find the answer you're looking for?</p>\n  </div>\n\n  <!-- QUICK HELP CARDS - dark green, icon + white uppercase text -->\n  <div style=\"display:grid;grid-template-columns:repeat(auto-fit, minmax(220px, 1fr));gap:16px;margin-bottom:14px;\">\n    <a href=\"/pages/tracking\" style=\"text-decoration:none;background:#152420;border-radius:10px;padding:26px 20px;text-align:center;display:flex;flex-direction:column;align-items:center;gap:12px;\">\n      <svg width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#f4a51c\" stroke-width=\"1.6\"><path d=\"M1 3h13v13H1z\"/><path d=\"M14 8h4l3 3v5h-7z\"/><circle cx=\"6\" cy=\"18\" r=\"2\"/><circle cx=\"17\" cy=\"18\" r=\"2\"/></svg>\n      <div style=\"font-size:13px;font-weight:700;text-transform:uppercase;color:#fff;letter-spacing:0.02em;\">Where is my order?</div>\n    </a>\n    <a href=\"/pages/returns-policy\" style=\"text-decoration:none;background:#152420;border-radius:10px;padding:26px 20px;text-align:center;display:flex;flex-direction:column;align-items:center;gap:12px;\">\n      <svg width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#f4a51c\" stroke-width=\"1.6\"><path d=\"M21 12a9 9 0 1 1-3-6.7\"/><path d=\"M21 3v6h-6\"/></svg>\n      <div style=\"font-size:13px;font-weight:700;text-transform:uppercase;color:#fff;letter-spacing:0.02em;\">I want to return an item</div>\n    </a>\n    <a href=\"#cancel\" style=\"text-decoration:none;background:#152420;border-radius:10px;padding:26px 20px;text-align:center;display:flex;flex-direction:column;align-items:center;gap:12px;\">\n      <svg width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#f4a51c\" stroke-width=\"1.6\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><path d=\"M15 9l-6 6M9 9l6 6\"/></svg>\n      <div style=\"font-size:13px;font-weight:700;text-transform:uppercase;color:#fff;letter-spacing:0.02em;\">I want to cancel an order</div>\n    </a>\n  </div>\n\n  <div style=\"margin-bottom:44px;font-size:13.5px;color:#444;\">\n    Have another question? <a href=\"/pages/help-center\" style=\"color:#152420;font-weight:700;text-decoration:underline;\">BROWSE HELP CENTER &rsaquo;</a>\n  </div>\n\n  <hr style=\"border:none;border-top:1px solid #EDEBE5;margin-bottom:36px;\">\n\n  <div style=\"text-align:center;margin-bottom:8px;\">\n    <h2 style=\"font-family:'Poppins',sans-serif;font-size:24px;font-weight:700;color:#152420;display:inline-block;position:relative;\">Contact Us!\n      <div style=\"border-bottom:3px dotted #152420;width:60%;margin:6px auto 0;\"></div>\n    </h2>\n  </div>\n\n  <div style=\"display:grid;grid-template-columns:1.2fr 1fr;gap:40px;margin:32px 0 40px;align-items:center;\">\n    <div style=\"font-size:14px;color:#444;line-height:1.9;\">\n      <p>For order status inquiry, please visit your order page <a href=\"/account\" style=\"color:#152420;font-weight:600;\">here</a>.</p>\n      <p>For tracking updates, please visit <a href=\"/pages/tracking\" style=\"color:#152420;font-weight:600;text-decoration:underline;\">this page</a>.</p>\n      <p>For other concerns, feel free to visit our Help Center Page <a href=\"/pages/help-center\" style=\"color:#152420;font-weight:600;\">here</a>.</p>\n    </div>\n    <div style=\"text-align:center;\">\n      <svg width=\"180\" height=\"140\" viewBox=\"0 0 180 140\" fill=\"none\">\n        <rect x=\"55\" y=\"55\" width=\"60\" height=\"70\" rx=\"4\" fill=\"#152420\"/>\n        <rect x=\"65\" y=\"40\" width=\"10\" height=\"20\" fill=\"#8A6E4A\"/>\n        <path d=\"M40 55 L90 30 L140 55 Z\" fill=\"#f4a51c\"/>\n        <rect x=\"70\" y=\"80\" width=\"40\" height=\"30\" fill=\"#F5F0E8\"/>\n      </svg>\n    </div>\n  </div>\n\n  <div style=\"display:grid;grid-template-columns:1.2fr 1fr;gap:40px;margin-bottom:40px;\">\n    <div>\n      <h2 style=\"font-family:'Poppins',sans-serif;font-size:20px;font-weight:700;color:#152420;margin-bottom:16px;\">Get in touch</h2>\n      {% form 'contact' %}\n        {%- if form.posted_successfully? -%}\n          <p style=\"color:#2f6b1f;font-size:13px;margin-bottom:12px;\">Thanks - we've received your message and will get back to you shortly.</p>\n        {%- endif -%}\n        <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;\">\n          <input type=\"text\" name=\"contact[name]\" placeholder=\"Your Name\" style=\"padding:11px 14px;border:1px solid #EDEBE5;border-radius:8px;font-size:13px;\">\n          <input type=\"email\" name=\"contact[email]\" placeholder=\"Your Email\" required style=\"padding:11px 14px;border:1px solid #EDEBE5;border-radius:8px;font-size:13px;\">\n        </div>\n        <div style=\"display:flex;flex-direction:column;gap:12px;\">\n          <input type=\"text\" name=\"contact[subject]\" placeholder=\"Subject\" style=\"padding:11px 14px;border:1px solid #EDEBE5;border-radius:8px;font-size:13px;\">\n          <textarea name=\"contact[body]\" rows=\"5\" placeholder=\"Your Message\" required style=\"padding:11px 14px;border:1px solid #EDEBE5;border-radius:8px;font-size:13px;font-family:inherit;\"></textarea>\n          <button type=\"submit\" style=\"background:#152420;color:#fff;border:none;padding:12px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;\">Send Message</button>\n        </div>\n      {% endform %}\n    </div>\n    <div>\n      <h2 style=\"font-family:'Poppins',sans-serif;font-size:20px;font-weight:700;color:#152420;margin-bottom:16px;\">Our Corporate Office</h2>\n      <div style=\"border-radius:10px;overflow:hidden;margin-bottom:16px;border:1px solid #EDEBE5;\">\n        <iframe\n          src=\"https://www.openstreetmap.org/export/embed.html?bbox=75.70%2C26.79%2C75.80%2C26.86&layer=mapnik&marker=26.822%2C75.752\"\n          style=\"width:100%;height:220px;border:none;display:block;\"\n          loading=\"lazy\">\n        </iframe>\n      </div>\n      <div style=\"display:grid;grid-template-columns:1fr;gap:16px;\">\n        <div>\n          <div style=\"font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:#8A6E4A;font-weight:600;margin-bottom:4px;\">Address</div>\n          <div style=\"font-size:13.5px;color:#333;\">Himank Path, Ganpati Nagar, Manyawas, Jaipur, Rajasthan, India &ndash; 302020</div>\n        </div>\n        <div>\n          <div style=\"font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:#8A6E4A;font-weight:600;margin-bottom:4px;\">Phone</div>\n          <div style=\"font-size:13.5px;color:#333;\">+91 8769325140 &mdash; Everyday 9am to 6pm</div>\n        </div>\n        <div>\n          <div style=\"font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:#8A6E4A;font-weight:600;margin-bottom:4px;\">Email</div>\n          <div style=\"font-size:13.5px;color:#333;\">support@furniva.in</div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <!-- CANCELLATION INFO -->\n  <div id=\"cancel\" style=\"background:#F7F5F1;border-radius:10px;padding:24px;\">\n    <h2 style=\"font-family:'Poppins',sans-serif;font-size:18px;font-weight:700;color:#152420;margin-bottom:14px;\">Canceling an Order at Furniva</h2>\n    <div style=\"font-size:13.5px;color:#444;line-height:1.7;\">\n      <p style=\"margin-bottom:10px;\"><strong>1. Order Confirmation:</strong> We confirm all orders via a phone call to ensure 100% clarity and satisfaction. If you haven't received a confirmation call yet, please wait for our team to contact you.</p>\n      <p style=\"margin-bottom:10px;\"><strong>2. Eligible Order Statuses for Cancellation:</strong> You can cancel your order if its status is On Hold, Processing, or Pending Payment.</p>\n      <p style=\"margin-bottom:10px;\"><strong>3. Orders in Transit:</strong> If your order has already been shipped, direct cancellation is not available. Please reach out to our support team for assistance.</p>\n      <p><strong>4. Cancellation Charges:</strong> In cases where an order is already in transit, a cancellation fee may apply, depending on the shipment status.</p>\n    </div>\n  </div>\n\n</div>"
      }
    }
  },
  "order": [
    "main"
  ]
