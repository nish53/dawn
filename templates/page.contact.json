{
  "sections": {
    "main": {
      "type": "custom-liquid",
      "settings": {
        "color_scheme": "scheme-1",
        "padding_top": 0,
        "padding_bottom": 0,
        "custom_liquid": "<div class=\"page-width\" style=\"padding:30px 0 50px;\">\n\n  <div style=\"text-align:center;margin-bottom:36px;\">\n    <h1 style=\"font-family:'Poppins',sans-serif;font-size:30px;font-weight:700;color:#152420;margin-bottom:10px;\">Hi, how can we help you?</h1>\n    <p style=\"font-size:14px;color:#666;\">Can't find the answer you're looking for?</p>\n  </div>\n\n  <!-- QUICK HELP CARDS -->\n  <div style=\"display:grid;grid-template-columns:repeat(auto-fit, minmax(200px, 1fr));gap:16px;margin-bottom:40px;\">\n    <a href=\"/pages/tracking\" style=\"text-decoration:none;background:#F7F5F1;border-radius:10px;padding:22px 18px;text-align:center;\">\n      <div style=\"font-size:14px;font-weight:700;color:#152420;\">Where is my order?</div>\n    </a>\n    <a href=\"/pages/returns-policy\" style=\"text-decoration:none;background:#F7F5F1;border-radius:10px;padding:22px 18px;text-align:center;\">\n      <div style=\"font-size:14px;font-weight:700;color:#152420;\">I want to return an item</div>\n    </a>\n    <a href=\"#cancel\" style=\"text-decoration:none;background:#F7F5F1;border-radius:10px;padding:22px 18px;text-align:center;\">\n      <div style=\"font-size:14px;font-weight:700;color:#152420;\">I want to cancel an order</div>\n    </a>\n  </div>\n\n  <div style=\"display:grid;grid-template-columns:1.2fr 1fr;gap:40px;margin-bottom:40px;\">\n    <div>\n      <h2 style=\"font-family:'Poppins',sans-serif;font-size:20px;font-weight:700;color:#152420;margin-bottom:16px;\">Get in touch</h2>\n      {% form 'contact' %}\n        {%- if form.posted_successfully? -%}\n          <p style=\"color:#2f6b1f;font-size:13px;margin-bottom:12px;\">Thanks - we've received your message and will get back to you shortly.</p>\n        {%- endif -%}\n        <div style=\"display:flex;flex-direction:column;gap:12px;\">\n          <input type=\"text\" name=\"contact[name]\" placeholder=\"Your Name\" style=\"padding:11px 14px;border:1px solid #EDEBE5;border-radius:8px;font-size:13px;\">\n          <input type=\"email\" name=\"contact[email]\" placeholder=\"Your Email\" required style=\"padding:11px 14px;border:1px solid #EDEBE5;border-radius:8px;font-size:13px;\">\n          <input type=\"text\" name=\"contact[phone]\" placeholder=\"Phone (optional)\" style=\"padding:11px 14px;border:1px solid #EDEBE5;border-radius:8px;font-size:13px;\">\n          <textarea name=\"contact[body]\" rows=\"5\" placeholder=\"Your Message\" required style=\"padding:11px 14px;border:1px solid #EDEBE5;border-radius:8px;font-size:13px;font-family:inherit;\"></textarea>\n          <button type=\"submit\" style=\"background:#152420;color:#fff;border:none;padding:12px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;\">Send Message</button>\n        </div>\n      {% endform %}\n    </div>\n    <div>\n      <h2 style=\"font-family:'Poppins',sans-serif;font-size:20px;font-weight:700;color:#152420;margin-bottom:16px;\">Our Corporate Office</h2>\n      <div style=\"background:#F7F5F1;border-radius:10px;padding:22px;\">\n        <div style=\"margin-bottom:16px;\">\n          <div style=\"font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:#8A6E4A;font-weight:600;margin-bottom:4px;\">Address</div>\n          <div style=\"font-size:13.5px;color:#333;\">Churu, Rajasthan, India &ndash; 331001</div>\n        </div>\n        <div style=\"margin-bottom:16px;\">\n          <div style=\"font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:#8A6E4A;font-weight:600;margin-bottom:4px;\">Phone</div>\n          <div style=\"font-size:13.5px;color:#333;\">+91 8769325140 &mdash; Everyday 9am to 6pm</div>\n        </div>\n        <div>\n          <div style=\"font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:#8A6E4A;font-weight:600;margin-bottom:4px;\">Email</div>\n          <div style=\"font-size:13.5px;color:#333;\">support@furniva.in</div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <!-- CANCELLATION INFO -->\n  <div id=\"cancel\" style=\"background:#F7F5F1;border-radius:10px;padding:24px;\">\n    <h2 style=\"font-family:'Poppins',sans-serif;font-size:18px;font-weight:700;color:#152420;margin-bottom:14px;\">Canceling an Order at Furniva</h2>\n    <div style=\"font-size:13.5px;color:#444;line-height:1.7;\">\n      <p style=\"margin-bottom:10px;\"><strong>1. Order Confirmation:</strong> We confirm all orders via a phone call to ensure 100% clarity and satisfaction. If you haven't received a confirmation call yet, please wait for our team to contact you.</p>\n      <p style=\"margin-bottom:10px;\"><strong>2. Eligible Order Statuses for Cancellation:</strong> You can cancel your order if its status is On Hold, Processing, or Pending Payment.</p>\n      <p style=\"margin-bottom:10px;\"><strong>3. Orders in Transit:</strong> If your order has already been shipped, direct cancellation is not available. Please reach out to our support team for assistance.</p>\n      <p><strong>4. Cancellation Charges:</strong> In cases where an order is already in transit, a cancellation fee may apply, depending on the shipment status.</p>\n    </div>\n  </div>\n\n</div>"
      }
    }
  },
  "order": [
    "main"
  ]
}