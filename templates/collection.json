{
  "sections": {
    "product-grid": {
      "type": "main-collection-product-grid",
      "settings": {
        "products_per_page": 16,
        "columns_desktop": 4,
        "color_scheme": "scheme-1",
        "image_ratio": "landscape",
        "image_shape": "default",
        "show_secondary_image": false,
        "show_vendor": false,
        "show_rating": false,
        "quick_add": "standard",
        "enable_filtering": true,
        "filter_type": "horizontal",
        "enable_sorting": true,
        "columns_mobile": "2",
        "padding_top": 20,
        "padding_bottom": 24
      }
    },
    "custom_hero": {
      "type": "custom-liquid",
      "settings": {
        "color_scheme": "scheme-1",
        "padding_top": 0,
        "padding_bottom": 0,
        "custom_liquid": "{%- liquid\n  assign handle = collection.handle\n  assign starting_price = 999999\n  for p in collection.products\n    if p.price_min < starting_price\n      assign starting_price = p.price_min\n    endif\n  endfor\n-%}\n\n<div class=\"page-width\" style=\"padding-top:20px;\">\n\n  <!-- BREADCRUMB -->\n  <div style=\"font-size:12px;color:#666;margin-bottom:14px;\">\n    <a href=\"/\" style=\"color:#666;text-decoration:none;\">Home</a> &rsaquo; <span style=\"color:#f4a51c;font-weight:600;\">{{ collection.title }}</span>\n  </div>\n\n  <!-- HERO BANNER -->\n  <div style=\"background:#F0ECE4;border-radius:14px;padding:32px 32px 28px;display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:20px;margin-bottom:20px;\">\n    <div>\n      <div style=\"font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:#8A6E4A;font-weight:600;margin-bottom:8px;\">{{ collection.title }} collection</div>\n      <h1 style=\"font-family:'Poppins',sans-serif;font-size:30px;font-weight:700;color:#152420;line-height:1.25;margin:0 0 10px;\">\n        {%- if collection.description != blank -%}\n          {{ collection.title }}\n        {%- else -%}\n          {{ collection.title }}\n        {%- endif -%}\n      </h1>\n      {%- if collection.description != blank -%}\n        <div style=\"font-size:14px;color:#5a5a5a;line-height:1.6;max-width:420px;margin-bottom:18px;\">{{ collection.description | strip_html | truncatewords: 24 }}</div>\n      {%- endif -%}\n      <div style=\"display:flex;gap:28px;\">\n        <div style=\"text-align:center;\">\n          <div style=\"font-family:'Poppins',sans-serif;font-size:22px;font-weight:700;color:#152420;\">{{ collection.products_count }}</div>\n          <div style=\"font-size:11px;color:#8A6E4A;\">Products</div>\n        </div>\n        <div style=\"text-align:center;\">\n          <div style=\"font-family:'Poppins',sans-serif;font-size:22px;font-weight:700;color:#152420;\">Free</div>\n          <div style=\"font-size:11px;color:#8A6E4A;\">Delivery + Install</div>\n        </div>\n        {%- if starting_price != 999999 -%}\n        <div style=\"text-align:center;\">\n          <div style=\"font-family:'Poppins',sans-serif;font-size:22px;font-weight:700;color:#152420;\">{{ starting_price | money_without_trailing_zeros }}</div>\n          <div style=\"font-size:11px;color:#8A6E4A;\">Starting from</div>\n        </div>\n        {%- endif -%}\n      </div>\n    </div>\n    {%- if collection.image -%}\n      <img src=\"{{ collection.image | image_url: width: 240 }}\" alt=\"{{ collection.title }}\" style=\"width:200px;height:150px;object-fit:cover;border-radius:10px;flex-shrink:0;\">\n    {%- endif -%}\n  </div>\n\n  <!-- TRUST BAR -->\n  <div style=\"display:flex;justify-content:space-around;flex-wrap:wrap;background:#F7F5F1;border:1px solid #EDEBE5;border-radius:10px;padding:14px 16px;margin-bottom:20px;gap:10px;\">\n    <div style=\"display:flex;align-items:center;gap:6px;font-size:12px;font-weight:600;color:#3a3a3a;\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#8A6E4A\" stroke-width=\"1.8\"><path d=\"M1 3h13v13H1z\"/><path d=\"M14 8h4l3 3v5h-7z\"/><circle cx=\"6\" cy=\"18\" r=\"2\"/><circle cx=\"17\" cy=\"18\" r=\"2\"/></svg>\n      Free Delivery\n    </div>\n    <div style=\"display:flex;align-items:center;gap:6px;font-size:12px;font-weight:600;color:#3a3a3a;\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#8A6E4A\" stroke-width=\"1.8\"><path d=\"M14.7 6.3a4 4 0 0 0-5.4 5.4L2 19l3 3 7.3-7.3a4 4 0 0 0 5.4-5.4l-2.5 2.5-2-2z\"/></svg>\n      Free Installation\n    </div>\n    <div style=\"display:flex;align-items:center;gap:6px;font-size:12px;font-weight:600;color:#3a3a3a;\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#8A6E4A\" stroke-width=\"1.8\"><path d=\"M12 2l8 4v6c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6z\"/><path d=\"M9 12l2 2 4-4\"/></svg>\n      Warranty Included\n    </div>\n    <div style=\"display:flex;align-items:center;gap:6px;font-size:12px;font-weight:600;color:#3a3a3a;\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#8A6E4A\" stroke-width=\"1.8\"><path d=\"M21 12a9 9 0 1 1-3-6.7\"/><path d=\"M21 3v6h-6\"/></svg>\n      3-Day Returns\n    </div>\n    <div style=\"display:flex;align-items:center;gap:6px;font-size:12px;font-weight:600;color:#3a3a3a;\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#8A6E4A\" stroke-width=\"1.8\"><rect x=\"2\" y=\"6\" width=\"20\" height=\"12\" rx=\"2\"/><circle cx=\"12\" cy=\"12\" r=\"3\"/></svg>\n      COD Available\n    </div>\n  </div>\n\n  <!-- SUB-CATEGORY PILLS -->\n  <div style=\"font-size:12px;font-weight:600;margin-bottom:10px;color:#666;\">Browse by type</div>\n  <div style=\"display:flex;flex-wrap:wrap;gap:8px;margin-bottom:24px;\">\n    {%- assign pill_handles = 'beds,shoe-racks,chest-of-drawers,kitchen-cabinets,4-seater-dining-sets,6-seater-dining-sets,work-study,tv-entertainment-units,side-tables,coffee-tables,bookshelves,chairs,tables' | split: ',' -%}\n    {%- assign pill_labels = 'Bunk Beds,Shoe Racks,Chest of Drawers,Kitchen Cabinets,4-Seater Dining,6-Seater Dining,Study,TV Units,Side Tables,Coffee Tables,Bookshelves,Chairs,Tables' | split: ',' -%}\n    {%- for h in pill_handles -%}\n      {%- assign pc = collections[h] -%}\n      {%- if pc -%}\n        {%- assign is_active = false -%}\n        {%- if h == handle -%}{%- assign is_active = true -%}{%- endif -%}\n        <a href=\"{{ pc.url }}\" style=\"text-decoration:none;border-radius:20px;padding:7px 16px;font-size:12px;font-weight:600;display:inline-flex;align-items:center;gap:6px;white-space:nowrap;{% if is_active %}background:#152420;color:#f4a51c;{% else %}background:#fff;border:1px solid #EDEBE5;color:#3a3a3a;{% endif %}\">\n          {{ pill_labels[forloop.index0] }}\n          <span style=\"font-size:10.5px;{% if is_active %}color:#c9a56e;{% else %}color:#999;{% endif %}\">({{ pc.products_count }})</span>\n        </a>\n      {%- endif -%}\n    {%- endfor -%}\n  </div>\n\n</div>"
      }
    },
    "seo_block": {
      "type": "custom-liquid",
      "settings": {
        "color_scheme": "scheme-1",
        "padding_top": 0,
        "padding_bottom": 40,
        "custom_liquid": "<div class=\"page-width\">\n  <hr style=\"border:none;border-top:1px solid #EDEBE5;margin:0 0 24px;\">\n  <div style=\"background:#F7F5F1;border-radius:10px;padding:18px 20px;font-size:13px;color:#666;line-height:1.7;\">\n    <strong style=\"color:#152420;\">About {{ collection.title }} at Furniva</strong> &mdash;\n    {%- if collection.description != blank -%}\n      {{ collection.description | strip_html }}\n    {%- else -%}\n      We stock {{ collection.products_count }} engineered wood pieces in this collection. All orders include free delivery and installation pan-India, with warranty on every piece and easy 3-day returns.\n    {%- endif -%}\n  </div>\n</div>"
      }
    }
  },
  "order": [
    "custom_hero",
    "product-grid",
    "seo_block"
  ]
}